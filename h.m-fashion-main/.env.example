# MongoDB Atlas (authentication)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mhfashion?retryWrites=true&w=majority
JWT_SECRET=your-long-random-secret-at-least-32-characters

# Supabase (catalog, orders, admin data — optional for local demo mode)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL (password reset links, canonical redirects — never trust client Origin)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email (production password reset via Resend)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=M.H.Fashion <noreply@yourdomain.com>

# Admin emails (server-side allowlist — promotion to admin requires email match)
ADMIN_EMAILS=admin@yourdomain.com

# One-time admin seed (run: npm run seed:admin) — never commit real passwords
# ADMIN_SEED_EMAIL=gohilmahendra424@gmail.com
# ADMIN_SEED_PASSWORD=your-secure-admin-password
# ADMIN_SEED_NAME=Gohil Mahendra
