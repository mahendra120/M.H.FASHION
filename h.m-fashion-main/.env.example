# MongoDB Atlas (authentication)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mhfashion?retryWrites=true&w=majority
JWT_SECRET=your-long-random-secret-at-least-32-characters

# Supabase (catalog, stock, coupons, reviews)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL (password reset links, order emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email (Resend)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=M.H.Fashion <noreply@yourdomain.com>

# Admin emails (server-side allowlist)
ADMIN_EMAILS=admin@yourdomain.com

# One-time admin seed (npm run seed:admin) — never commit real passwords
# ADMIN_SEED_EMAIL=admin@yourdomain.com
# ADMIN_SEED_PASSWORD=your-secure-admin-password
# ADMIN_SEED_NAME=Admin User
