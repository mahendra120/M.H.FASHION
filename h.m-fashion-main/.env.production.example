# Production environment — set these in Vercel (or your host) for every environment: Production.
# Never commit real secrets. Copy variable names only.

# Required
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mhfashion?retryWrites=true&w=majority
JWT_SECRET=generate-with-openssl-rand-base64-32-min-32-chars
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=https://m-h-fashion.vercel.app
RESEND_API_KEY=re_your_production_key
ADMIN_EMAILS=admin@yourdomain.com

# Recommended
EMAIL_FROM=M.H.Fashion <onboarding@resend.dev>
# After verifying your domain at resend.com → Domains:
# EMAIL_FROM=M.H.Fashion <noreply@yourdomain.com>

# Admin seed (for npm run seed:admin:remote after deploy)
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=your-secure-password
ADMIN_SEED_NAME=Admin User

# Optional — distributed rate limiting (Upstash Redis free tier)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Security: if RESEND_API_KEY was exposed, revoke at resend.com → API Keys → create new → update Vercel

# Optional bootstrap (env-only admin without MongoDB user document)
# Prefer seed:admin:remote when MONGODB_URI is set

# Apply Supabase migrations after deploy:
# supabase/migrations/20260626060000_atomic_stock_and_coupon_limits.sql
# (plus earlier security migrations in supabase/migrations/)
